# Disable LiteSpeed/browser caching site-wide while actively developing
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
        Header set X-LiteSpeed-Cache-Control "no-cache"
    </FilesMatch>
</IfModule>

<IfModule LiteSpeed>
    <FilesMatch "\.(css|js|php)$">
        CacheDisable public
    </FilesMatch>
    CacheLookup off
</IfModule>

# ── Clean URLs (hide .php extension) ─────────────────────
# Public site only; /admin/ keeps explicit .php links untouched.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1) Redirect requests that still show .php to the clean URL (301, SEO-safe)
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /(?!admin/)([^?\s]+)\.php[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L]

    # 2) Internally serve the matching .php file for extension-less requests
    RewriteCond %{REQUEST_URI} !^/admin/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^(.+)$ $1.php [L,QSA]
</IfModule>
